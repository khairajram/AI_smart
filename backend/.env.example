# ─────────────────────────────────────────────────────────────────────────────
# ReID Analytics Dashboard – Environment Variables
# Copy this file to .env and adjust values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP port the Node server listens on
PORT=3000

# URL of the Python FastAPI ReID backend
PYTHON_API_URL=http://localhost:8000

# Set to 'false' to force live mode (requires Python API to be running)
# When 'true' (default), demo mode activates automatically if Python is unreachable
DEMO_MODE=true

# SQLite database path (relative to backend/ directory, or absolute)
DB_PATH=./reid_events.db

# How often (ms) the demo event simulator fires a new event (base interval)
SIMULATE_INTERVAL_MS=2000

# Comma-separated list of camera IDs
CAMERAS=ENTRANCE,AISLE_1,CHECKOUT

# ReID matching thresholds (0.0 – 1.0)
REID_THRESHOLD=0.82
REENTRY_THRESHOLD=0.80

# Maximum seconds between exit and re-entry to count as re-entry
REENTRY_WINDOW_SECONDS=300

# How often (ms) to broadcast metrics + cameras to the dashboard
METRICS_BROADCAST_INTERVAL_MS=2000

# How often (ms) to persist a metric snapshot and broadcast registry
SNAPSHOT_INTERVAL_MS=10000

# How often (ms) to poll the Python API for metrics when in live mode
PYTHON_POLL_INTERVAL_MS=2000
