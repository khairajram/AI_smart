# ─────────────────────────────────────────────────────────────────────
#  Store Intelligence API — Environment Configuration
#  Copy this file to .env and edit as needed.
# ─────────────────────────────────────────────────────────────────────

# ── ReID model ───────────────────────────────────────────────────────
REID_SIMILARITY_THRESHOLD=0.82       # Cross-camera match threshold (0.75–0.90)
REENTRY_SIMILARITY_THRESHOLD=0.80    # Re-entry match threshold (slightly lower)
REENTRY_WINDOW_SECONDS=300           # Re-entry detection window (seconds)
ACTIVE_VISITOR_TIMEOUT_SECONDS=30    # Auto-expire active visitors after N seconds
REID_DEVICE=auto                     # auto | cuda | cpu | mps
OSNET_MODEL_NAME=osnet_x1_0          # osnet_x1_0 | osnet_x0_75 | osnet_x0_5

# ── Detection ────────────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt                # yolov8n.pt | yolov8s.pt | yolov8m.pt
YOLO_CONFIDENCE=0.40

# ── Staff detection (Tier 1 — Spatial zone) ──────────────────────────
# Fraction of frame height from the TOP treated as a "staff-only zone".
# Default: 0.15 = top 15% of frame.
# Increase if your checkout counters appear high in the camera view.
# Set to 0.0 to disable Tier 1.
STAFF_ZONE_TOP_PCT=0.15

# ── Staff detection (Tier 2 — Static dwell) ──────────────────────────
# Centroid movement std-dev (pixels) below which a track is "static"
STAFF_STATIC_STD_PX=8.0
# Frames with low movement before declaring staff (at 25fps: 150 = 6 seconds)
STAFF_DWELL_FRAMES=150

# ── Staff detection (Tier 3 — Uniform colour) ────────────────────────
# Set HUE_MIN and HUE_MAX (OpenCV HSV: 0-179) to enable colour detection.
# Example: blue uniforms → 100-130 | green uniforms → 35-85
# Leave as -1 to DISABLE uniform colour detection.
STAFF_UNIFORM_HUE_MIN=-1
STAFF_UNIFORM_HUE_MAX=-1
STAFF_UNIFORM_COVERAGE_THRESHOLD=0.40

# ── API ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console

# ── Event publishing ─────────────────────────────────────────────────
EVENT_PUBLISHER=stdout               # stdout | redis
REDIS_URL=redis://localhost:6379/0
